# Atlas ERP Configuration
# Copy this file to .env and adjust values for your environment.

# Server
BIND_ADDR=0.0.0.0:8080
RUST_ENV=development

# Database
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
DB_MAX_CONNECTIONS=20

# Authentication
# IMPORTANT: Set a strong random secret (>= 32 characters) in production!
# Generate with: openssl rand -base64 48
JWT_SECRET=dev-secret-key-please-change-in-production-1234567890

# NATS Event Bus
NATS_URL=nats://localhost:4222

# CORS (comma-separated origins, leave empty for development mode)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Logging
RUST_LOG=info,atlas_gateway=debug
