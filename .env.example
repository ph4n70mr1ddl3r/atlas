# Atlas ERP Configuration
# Copy this file to .env and adjust values for your environment.

# Server
BIND_ADDR=0.0.0.0:8080
RUST_ENV=development

# Database
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
DB_MAX_CONNECTIONS=20

# Authentication
# IMPORTANT: Generate a strong random secret (>= 32 characters)!
#   openssl rand -base64 48
# Never commit actual secrets to version control.
JWT_SECRET=

# NATS Event Bus
NATS_URL=nats://localhost:4222

# CORS (comma-separated origins, leave empty for development mode)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Logging
RUST_LOG=info,atlas_gateway=debug
